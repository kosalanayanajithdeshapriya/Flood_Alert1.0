# ============================================================
#  Flood Alert App – Environment Variables
#  Copy this file to .env and fill in the values.
# ============================================================

# Port for the Express server (default: 3000)
PORT=3000

# ✏️  Path to your Firebase Service Account JSON file.
#    Download from: Firebase Console → Project Settings →
#    Service Accounts → "Generate new private key"
#    Place the JSON file in the project root and set the path below.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
